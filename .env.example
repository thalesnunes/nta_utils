TELEGRAM_BOT_TOKEN=your-token-here

# Optional: comma-separated list of allowed Telegram user IDs
# Leave empty or unset to allow everyone
# To find your ID, message @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=

# Google Calendar (optional — only needed for /days_off)
GCAL_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GCAL_CREDENTIALS_PATH=/app/credentials/credentials.json
